{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "justenough",
  "main": "./dist/server/index.js",
  "compatibility_date": "2026-05-15",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS"
  },
  "r2_buckets": [
    {
      "binding": "CORPUS",
      "bucket_name": "justenough-corpus"
    }
  ],
  "observability": {
    "enabled": true
  }
}
