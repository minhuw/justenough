# Enable the three LLM calls used for profiling, reranking, and final selection.
JUSTENOUGH_ENABLE_LLM=false
OPENAI_API_KEY=
JUSTENOUGH_PROFILE_MODEL=gpt-5.6-luna

# Must match the model and dimensions used by data:build-retrieval-index.
JUSTENOUGH_EMBEDDING_MODEL=text-embedding-3-small
JUSTENOUGH_EMBEDDING_DIMENSIONS=256

# Optional OpenAI-compatible API root.
# OPENAI_BASE_URL=https://api.openai.com/v1
