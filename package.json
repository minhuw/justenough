{
  "name": "just-enough",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "data:sync-outcomes": "node scripts/sync-outcomes.mjs",
    "data:extract:deepswe": "node scripts/extract-deepswe.mjs",
    "data:extract:terminal-bench": "node scripts/extract-terminal-bench.mjs",
    "data:validate-corpus": "node scripts/validate-corpus.mjs",
    "data:build-corpus": "node scripts/build-corpus-manifest.mjs",
    "data:build-fixtures": "node scripts/build-normalization-fixtures.mjs",
    "data:build-index": "node scripts/build-evidence-index.mjs",
    "data:build-retrieval-index": "node scripts/build-retrieval-index.mjs",
    "data:upload-r2": "node scripts/upload-corpus-r2.mjs",
    "deploy:cloudflare": "npm run build && wrangler deploy",
    "validate:deployment": "node scripts/validate-deployment.mjs"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
